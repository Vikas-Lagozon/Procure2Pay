# ──────────────────────────────────────────────────────────────
# SESSION MANAGEMENT — SQLAlchemy (PostgreSQL)
# ──────────────────────────────────────────────────────────────
DB_SCHEMA="public"

# ──────────────────────────────────────────────────────────────
# Attachment & Storage
# ──────────────────────────────────────────────────────────────
ATTACHMENT_DIR=ATTACHMENTS
MAX_ATTACHMENT_SIZE_MB=25

# ──────────────────────────────────────────────────────────────
# Application Settings
# ──────────────────────────────────────────────────────────────
APP_NAME=Jarvis
USER_ID=user_001
DEBUG=false

# ──────────────────────────────────────────────────────────────
# Knowledge Base
# ──────────────────────────────────────────────────────────────
KNOWLEDGE_BASE_DIR=Knowledge_Base

# ──────────────────────────────────────────────────────────────
# Gmail OAuth2
# ──────────────────────────────────────────────────────────────
# Path to client credentials JSON (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_FILE=credentials.json

# Token file (auto-generated after first OAuth flow)
GMAIL_TOKEN_FILE=token.json

# Default sender for outgoing emails
DEFAULT_SENDER_EMAIL=vikas.prajapati@lagozon.com
DEFAULT_SENDER_NAME=Vikas Prajapati

# ──────────────────────────────────────────────────────────────
# Email Fetch & Retry Settings
# ──────────────────────────────────────────────────────────────
EMAIL_FETCH_MAX_RESULTS=10
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=2.0

# ──────────────────────────────────────────────────────────────
# HITL (Human-in-the-Loop)
# ──────────────────────────────────────────────────────────────
HITL_DB_URL=sqlite:///hitl.db

